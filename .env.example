# Copy to .env and fill in. Never commit your real .env.

# --- LLM provider ---
# Your API key for the chosen provider (default provider: Anthropic / Claude API).
ANTHROPIC_API_KEY=

# Model to use. Set to a current model string for your provider.
# Do not rely on a hardcoded default in source — set it explicitly here.
DISTIL_MODEL=

# --- Embeddings / read layer ---
# Embedder backend: "local" (provider-independent, runs a local model) or "api".
DISTIL_EMBEDDER=local
# Embedding model name for the chosen backend.
DISTIL_EMBED_MODEL=
# Minimum similarity for a note to clear the abstention gate (0.0–1.0).
# Below this, `ask` returns "no relevant notes" and never calls the LLM to answer.
DISTIL_RETRIEVAL_THRESHOLD=0.35
# How many candidate items to retrieve per question.
DISTIL_TOP_K=6

# --- Storage ---
DISTIL_DB_PATH=./data/distil.db
DISTIL_KB_DIR=./kb
# When hosting (e.g. Railway), point these at the mounted volume, e.g. /data/distil.db and /data/kb.

# --- Hosting / auth ---
# Set true when exposing the app on a public URL. The app refuses to serve in public
# mode unless DISTIL_AUTH_SECRET is set.
DISTIL_PUBLIC=false
# Single-user login secret. REQUIRED whenever the app is not bound to localhost.
DISTIL_AUTH_SECRET=

# --- Behavior ---
# Fraction of application links reserved as novelty/serendipity (anti filter-bubble). 0.0–1.0
DISTIL_NOVELTY_RATIO=0.2

# EMA learning rate for profile weight updates (0.0–1.0). Lower = more gradual.
DISTIL_PROFILE_ALPHA=0.3
